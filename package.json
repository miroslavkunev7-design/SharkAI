{
  "name": "sharkai",
  "version": "1.0.0",
  "description": "SharkAI — Autonomous AI Software Engineering Platform",
  "private": true,
  "main": "electron/main.cjs",
  "author": "SharkAI",
  "scripts": {
    "dev": "next dev --port 3847",
    "build": "prisma generate && next build",
    "start": "next start --port 3847",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "node scripts/test-suite.cjs",
    "test:all": "node scripts/test-suite.cjs",
    "logo:process": "node scripts/process-logo.cjs",
    "desktop:shortcut": "node scripts/create-desktop-shortcut.cjs",
    "postinstall": "prisma generate",
    "electron:dev": "concurrently -k \"next dev --port 3847\" \"wait-on http://localhost:3847 && electron .\"",
    "electron:build": "npm run build && node scripts/prepare-electron.cjs && electron-builder --win",
    "electron:install": "npm run electron:build && node scripts/install-desktop.cjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.68",
    "@ai-sdk/react": "^3.0.199",
    "@prisma/client": "^6.1.0",
    "@vercel/functions": "^3.7.1",
    "ai": "^6.0.197",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "framer-motion": "^11.15.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "dotenv": "^17.4.2",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.16",
    "to-ico": "^1.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.sharkai.platform",
    "productName": "SharkAI",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "installerLanguages": [
        "en",
        "bg"
      ],
      "language": "1033",
      "shortcutName": "SharkAI",
      "runAfterFinish": true,
      "artifactName": "SharkAI-Setup-${version}.${ext}",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      ".next/standalone/**/*",
      "electron/**/*",
      "public/icon.ico",
      "public/logo-icon.png",
      "public/logo.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app"
      }
    ]
  }
}
