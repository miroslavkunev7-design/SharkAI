# SharkAI — Production Environment

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
JWT_SECRET="change-me-long-random-secret"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Windows installer (for Vercel — host .exe on GitHub Releases / Blob)
INSTALLER_DOWNLOAD_URL=""
