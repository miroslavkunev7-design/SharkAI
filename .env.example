INSTALLER_SIZE_MB="120"
ADMIN_EMAIL="mkunev77@abv.bg"
ADMIN_PASSWORD="your-admin-password"
USE_DB_UPLOADS="true"

# Optional AI (off by default)
SHARKAI_USE_PAID_AI="false"
OPENAI_API_KEY=""
